{
  "name": "tfi",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "AI-Powered Investment Analysis Platform",
  "scripts": {
    "dev": "concurrently -n \"server,client\" -c \"blue,green\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "npm run dev --prefix packages/server",
    "migrate:server": "npm run migrate --prefix packages/server",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:llm": "vitest run src/features/live-monitor/__tests__/ai-integration.test.ts src/features/live-monitor/__tests__/ai-prompt-audit.test.ts",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "verify:ci": "npm run typecheck --prefix packages/server && npm run test --prefix packages/server && npm run data-driven:verify-gates-ci --prefix packages/server && npm run typecheck && npm run test",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "deploy:azure": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/azure/deploy.ps1"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.0.0",
    "msw": "^2.12.11",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.2.4",
    "workbox-expiration": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thihx/tfi.git"
  },
  "bugs": {
    "url": "https://github.com/thihx/tfi/issues"
  },
  "homepage": "https://github.com/thihx/tfi#readme"
}
