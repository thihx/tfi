{
  "name": "@tfi/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts",
    "replay:pipeline": "tsx src/scripts/replay-pipeline.ts",
    "replay:pipeline-suite": "tsx src/scripts/replay-pipeline-suite.ts",
    "replay:strategic-context-suite": "tsx src/scripts/replay-strategic-context-suite.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:delivery-runtime": "tsx src/scripts/verify-delivery-runtime.ts",
    "replay:fixtures:structural": "tsx src/scripts/emit-structural-settled-replay-fixtures.ts",
    "replay:eval:structural": "tsx src/scripts/evaluate-settled-prompt-variants.ts --dir fixtures/settled-replay-structural --prompt-version v8-market-balance-followup-h --prompt-version v10-hybrid-legacy-b --llm mock --odds mock --delay-ms 0 --report-json replay-baselines/structural-replay-summary.json --report-md replay-baselines/structural-replay-summary.md --report-cases-json replay-baselines/structural-replay-cases.json",
    "replay:audit:odds:smoke": "tsx src/scripts/audit-replay-odds-integrity.ts --dir fixtures/odds-audit-smoke --report-json replay-baselines/last-odds-audit-smoke.json",
    "replay:audit:odds:structural": "tsx src/scripts/audit-replay-odds-integrity.ts --dir fixtures/settled-replay-structural --report-json replay-baselines/last-odds-audit-structural-replay.json",
    "replay:audit:market:structural": "tsx src/scripts/audit-replay-market-opportunities.ts --dir fixtures/settled-replay-structural --min-odds 1.5 --report-json replay-baselines/structural-market-opportunities.json --report-md replay-baselines/structural-market-opportunities.md",
    "replay:ou-under:integration": "tsx src/scripts/run-ou-under-replay-integration.ts",
    "replay:ou-under:integration:structural": "tsx src/scripts/run-ou-under-replay-integration.ts --structural",
    "replay:ou-under:integration:n20": "tsx src/scripts/run-ou-under-replay-integration.ts --limit 20",
    "replay:ou-under:integration:n40": "tsx src/scripts/run-ou-under-replay-integration.ts --limit 40",
    "replay:ou-under:integration:n60": "tsx src/scripts/run-ou-under-replay-integration.ts --limit 60",
    "replay:ou-under:check-gates": "tsx src/scripts/check-replay-integration-gates.ts",
    "replay:benchmark:export": "tsx src/scripts/export-settled-replay-scenarios.ts --out-dir replay-benchmarks/goals-totals-benchmark --lookback-days 14 --limit 120 --market-family goals_totals",
    "replay:benchmark:export:all": "tsx src/scripts/export-settled-replay-scenarios.ts --out-dir replay-benchmarks/all-markets-benchmark --lookback-days 14 --limit 120 --market-family all",
    "replay:benchmark:eval": "tsx src/scripts/run-replay-benchmark-eval.ts",
    "replay:benchmark:eval:policy": "tsx src/scripts/run-replay-benchmark-eval.ts --apply-replay-policy",
    "replay:benchmark:eval:policy:all-markets": "tsx src/scripts/run-replay-benchmark-eval.ts --apply-replay-policy --bench-dir replay-benchmarks/all-markets-benchmark --odds mock",
    "replay:benchmark:eval:policy:all-markets:recorded": "tsx src/scripts/run-replay-benchmark-eval.ts --apply-replay-policy --bench-dir replay-benchmarks/all-markets-benchmark --odds recorded",
    "replay:benchmark:eval:dual": "tsx src/scripts/run-replay-benchmark-dual.ts",
    "replay:benchmark:check-gates": "tsx src/scripts/check-replay-integration-gates.ts --config replay-benchmark-gates.json",
    "replay:benchmark:check-gates:policy": "tsx src/scripts/check-replay-integration-gates.ts --config replay-benchmark-gates-policy.json",
    "replay:benchmark:check-gates:targets": "tsx src/scripts/check-replay-integration-gates.ts --config replay-benchmark-gates-policy-targets.json",
    "analyze:goals-totals-recent": "tsx src/scripts/analyze-goals-totals-recent.ts",
    "data-driven:coverage": "tsx src/scripts/report-recommendation-snapshot-coverage.ts",
    "data-driven:replay-batch": "tsx src/scripts/run-data-driven-replay-batch.ts",
    "data-driven:improvement-run": "tsx src/scripts/run-data-driven-replay-batch.ts --lookback-days 14 --limit 50 --max-scenarios 30 --llm mock --delay-ms 0 --odds recorded --apply-replay-policy",
    "data-driven:summarize-vs-original": "tsx src/scripts/summarize-replay-vs-original.ts",
    "data-driven:check-gates": "tsx src/scripts/check-data-driven-replay-gates.ts",
    "data-driven:segment-hotspots": "tsx src/scripts/summarize-replay-segment-hotspots.ts",
    "data-driven:check-segment-gates": "tsx src/scripts/check-data-driven-segment-gates.ts",
    "data-driven:verify-gates-ci": "tsx src/scripts/check-data-driven-replay-gates.ts --config ci-baselines/data-driven-gates/gates-delta.ci.json && tsx src/scripts/check-data-driven-segment-gates.ts --config ci-baselines/data-driven-gates/gates-segment.ci.json",
    "data-driven:suggest-segment-blocklist": "tsx src/scripts/suggest-segment-policy-blocklist.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/static": "^9.0.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "ioredis": "^5.10.0",
    "pg": "^8.16.0",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/pg": "^8.12.0",
    "@types/web-push": "^3.6.4",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
