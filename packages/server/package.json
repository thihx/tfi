{
  "name": "@tfi/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts",
    "replay:pipeline": "tsx src/scripts/replay-pipeline.ts",
    "replay:pipeline-suite": "tsx src/scripts/replay-pipeline-suite.ts",
    "replay:strategic-context-suite": "tsx src/scripts/replay-strategic-context-suite.ts",
    "replay:web-live-fallback-suite": "tsx src/scripts/replay-web-live-fallback-suite.ts",
    "benchmark:live-score": "tsx src/scripts/benchmark-live-score.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/static": "^9.0.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "ioredis": "^5.10.0",
    "pg": "^8.16.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/pg": "^8.12.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
