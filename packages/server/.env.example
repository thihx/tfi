# Server Environment
DATABASE_URL=postgresql://user:password@host:5432/tfi?sslmode=require
# Required for replay integration (evaluate-settled-prompt-variants, self-audit Step C)
GEMINI_API_KEY=
PORT=4000
CORS_ORIGIN=http://localhost:3000
GEMINI_TIMEOUT_MS=90000
# Live pipeline / default proxy model (often Pro in production)
# GEMINI_MODEL=gemini-3-pro-preview
# Auto-settle AI fallback only — cheaper default than full pipeline
GEMINI_SETTLE_MODEL=gemini-2.5-flash

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FRONTEND_URL=http://localhost:3000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN_SECONDS=86400
ALLOWED_EMAILS=

# Strategic context source policy overrides (comma-separated, optional)
STRATEGIC_OFFICIAL_DOMAINS=
STRATEGIC_MAJOR_NEWS_DOMAINS=
STRATEGIC_STATS_REFERENCE_DOMAINS=
STRATEGIC_REJECTED_DOMAIN_PATTERNS=
STRATEGIC_AGGREGATOR_PATTERNS=

# Strategic context Gemini tuning
GEMINI_STRATEGIC_GROUNDED_MODEL=gemini-2.5-flash
GEMINI_STRATEGIC_STRUCTURED_MODEL=gemini-2.5-flash
GEMINI_STRATEGIC_GROUNDED_MAX_OUTPUT_TOKENS=4000
GEMINI_STRATEGIC_STRUCTURED_MAX_OUTPUT_TOKENS=2048
GEMINI_STRATEGIC_GROUNDED_THINKING_BUDGET=0
GEMINI_STRATEGIC_STRUCTURED_THINKING_BUDGET=0

# Housekeeping / retention
JOB_HOUSEKEEPING_MS=86400000
AUDIT_KEEP_DAYS=30
MATCHES_HISTORY_KEEP_DAYS=120
PROVIDER_SAMPLES_KEEP_DAYS=14
MATCH_SNAPSHOTS_KEEP_DAYS=14
ODDS_MOVEMENTS_KEEP_DAYS=30
PROMPT_SHADOW_KEEP_DAYS=14

# Live analysis prompts (deploy: set ACTIVE explicitly or omit to use code default v10-hybrid-legacy-b)
LIVE_ANALYSIS_ACTIVE_PROMPT_VERSION=v10-hybrid-legacy-b
# Prompt shadow (second LLM call): keep disabled until LIVE_ANALYSIS_SHADOW_PROMPT_VERSION is refreshed
LIVE_ANALYSIS_SHADOW_PROMPT_VERSION=
LIVE_ANALYSIS_SHADOW_ENABLED=false
LIVE_ANALYSIS_SHADOW_SAMPLE_RATE=0

# Optional: block recommendations when minuteBand::marketFamily matches (see segment-policy-blocklist.example.json)
# SEGMENT_POLICY_BLOCKLIST_PATH=segment-policy-blocklist.json
# Optional: cap stake % per segment key (see segment-policy-stake-cap.example.json)
# SEGMENT_POLICY_STAKE_CAP_PATH=segment-policy-stake-cap.json
