# Server Environment
DATABASE_URL=postgresql://user:password@host:5432/tfi?sslmode=require
# Required for replay integration (evaluate-settled-prompt-variants, self-audit Step C)
GEMINI_API_KEY=
PORT=4000
CORS_ORIGIN=http://localhost:3000
GEMINI_TIMEOUT_MS=90000
# Live pipeline / default proxy model
# GEMINI_MODEL=gemini-3.5-flash
PIPELINE_MIN_CONFIDENCE=7

# Runtime policy-shadow controlled production promotion (Phase 4, default off).
# Requires readiness gates + human review before setting EVIDENCE_ACK=ready_for_human_review.
RUNTIME_POLICY_PROMOTION_ENABLED=false
RUNTIME_POLICY_PROMOTION_KILL_SWITCH=false
RUNTIME_POLICY_PROMOTION_POCKET_IDS=
RUNTIME_POLICY_PROMOTION_ROLLOUT_PERCENT=0
RUNTIME_POLICY_PROMOTION_MAX_STAKE_PERCENT=1
RUNTIME_POLICY_PROMOTION_EVIDENCE_ACK=
RUNTIME_POLICY_PROMOTION_OWNER=
# Auto-settle AI fallback only â€” cheaper default than full pipeline
GEMINI_SETTLE_MODEL=gemini-3.5-flash

# Football API (API-Sports)
FOOTBALL_API_KEY=
FOOTBALL_API_DAILY_LIMIT=7500
# Pause outbound Football API calls until UTC midnight after daily quota is hit
FOOTBALL_API_CIRCUIT_ENABLED=true

# Sportmonks provider 2. Defaults off. Shadow script never save/notify.
# Stats/events fallback is opt-in and still must pass existing money guards.
SPORTMONKS_ENABLED=false
SPORTMONKS_SHADOW_ENABLED=false
SPORTMONKS_API_TOKEN=
SPORTMONKS_BASE_URL=https://api.sportmonks.com/v3/football
SPORTMONKS_SHADOW_MAX_CALLS_PER_RUN=10
SPORTMONKS_PRIORITY_LEAGUE_IDS=
JOB_SPORTMONKS_SHADOW_POC_MS=0
SPORTMONKS_ALLOW_STATS_FALLBACK=false
SPORTMONKS_ALLOW_EVENTS_FALLBACK=false
SPORTMONKS_ALLOW_ODDS_FALLBACK=false

# Provider fusion Phase 6. Shadow audit only; promotion must remain false until later phases pass gates.
PROVIDER_FUSION_ENABLED=false
PROVIDER_FUSION_SHADOW_ENABLED=false
PROVIDER_FUSION_PROMOTION_ENABLED=false
PROVIDER_FUSION_STATS_EVENTS_PROMOTION=false
PROVIDER_FUSION_ODDS_SHADOW_ENABLED=false
PROVIDER_FUSION_ODDS_PROMOTION=false
PROVIDER_FUSION_ODDS_PROVIDER_ALLOWLIST=
PROVIDER_FUSION_ROLLOUT_PERCENT=0
PROVIDER_FUSION_KILL_SWITCH=false

# Job intervals (ms) â€” 0 disables a job. Code defaults in config.ts; production tuning below.
# JOB_FETCH_MATCHES_MS=120000
# JOB_REFRESH_LIVE_MATCHES_MS=3000
# JOB_REFRESH_LIVE_MATCHES_REALTIME_FIXTURE_MS=5000
# JOB_REFRESH_LIVE_MATCHES_BACKGROUND_FIXTURE_MS=15000
# JOB_REFRESH_LIVE_MATCHES_MAX_PUBLIC_MATCHES=20
# JOB_REFRESH_LIVE_MATCHES_PUBLIC_MS=15000
# JOB_CHECK_MATCH_ALERTS_MS=3000
# JOB_DELIVER_TELEGRAM_NOTIFICATIONS_MS=3000
# JOB_CHECK_LIVE_MS=120000
# JOB_REFRESH_PROVIDER_INSIGHTS_MS=300000
# JOB_ENRICH_WATCHLIST_MAX_PER_RUN=20
# JOB_AUTO_ADD_TOP_LEAGUE_WATCHLIST_MS=0
# REFRESH_PROVIDER_INSIGHTS_API_BUDGET=30
# Production quota tuning (Phase 2 â€” change one var at a time, monitor /api/integration-health):
# JOB_AUTO_ADD_TOP_LEAGUE_WATCHLIST_MS=0
# JOB_REFRESH_LIVE_MATCHES_MS=3000
# JOB_REFRESH_LIVE_MATCHES_REALTIME_FIXTURE_MS=5000
# JOB_REFRESH_LIVE_MATCHES_BACKGROUND_FIXTURE_MS=15000
# JOB_REFRESH_LIVE_MATCHES_MAX_PUBLIC_MATCHES=20
# JOB_REFRESH_LIVE_MATCHES_PUBLIC_MS=15000
# JOB_CHECK_MATCH_ALERTS_MS=3000
# JOB_DELIVER_TELEGRAM_NOTIFICATIONS_MS=3000
# JOB_FETCH_MATCHES_MS=120000
# JOB_REFRESH_PROVIDER_INSIGHTS_MS=300000
# JOB_CHECK_LIVE_MS=120000
# JOB_ENRICH_WATCHLIST_MAX_PER_RUN=20
# REFRESH_PROVIDER_INSIGHTS_API_BUDGET=30

# Native push (FCM HTTP v1). Use Firebase Messaging for Capacitor iOS/Android.
# Either set FCM_SERVICE_ACCOUNT_JSON, or set the three split vars below.
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
# FCM_SERVICE_ACCOUNT_JSON=
NATIVE_PUSH_DEVICE_KEEP_DAYS=180

# Critical fallback SMS/voice (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
CRITICAL_FALLBACK_SMS_ENABLED=false
CRITICAL_FALLBACK_VOICE_CALL_ENABLED=false
CRITICAL_FALLBACK_SMS_MAX_PER_USER_DAY=10
CRITICAL_FALLBACK_VOICE_CALL_MAX_PER_USER_DAY=3
CRITICAL_FALLBACK_SMS_MAX_GLOBAL_DAY=0
CRITICAL_FALLBACK_VOICE_CALL_MAX_GLOBAL_DAY=0
CRITICAL_FALLBACK_SMS_ESTIMATED_UNIT_COST_USD=0
CRITICAL_FALLBACK_VOICE_CALL_ESTIMATED_UNIT_COST_USD=0

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FRONTEND_URL=http://localhost:3000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN_SECONDS=86400
ALLOWED_EMAILS=

# Strategic context source policy overrides (comma-separated, optional)
STRATEGIC_OFFICIAL_DOMAINS=
STRATEGIC_MAJOR_NEWS_DOMAINS=
STRATEGIC_STATS_REFERENCE_DOMAINS=
STRATEGIC_REJECTED_DOMAIN_PATTERNS=
STRATEGIC_AGGREGATOR_PATTERNS=

# Strategic context Gemini tuning
GEMINI_STRATEGIC_GROUNDED_MODEL=gemini-3.5-flash
GEMINI_STRATEGIC_STRUCTURED_MODEL=gemini-3.5-flash
GEMINI_STRATEGIC_GROUNDED_MAX_OUTPUT_TOKENS=4000
GEMINI_STRATEGIC_STRUCTURED_MAX_OUTPUT_TOKENS=2048
GEMINI_STRATEGIC_GROUNDED_THINKING_BUDGET=0
GEMINI_STRATEGIC_STRUCTURED_THINKING_BUDGET=0

# AI Gateway control plane
AI_GATEWAY_MODE=enforce
AI_GATEWAY_MAX_INPUT_TOKENS=80000
AI_GATEWAY_MAX_ESTIMATED_COST_USD_PER_CALL=0.5
AI_GATEWAY_LOOP_WINDOW_MINUTES=5
AI_GATEWAY_LOOP_CALL_THRESHOLD=6
AI_GATEWAY_ALERTS_ENABLED=true
# Emergency kill switches (comma-separated)
AI_GATEWAY_DISABLED_FEATURES=
AI_GATEWAY_DISABLED_OPERATIONS=
AI_GATEWAY_DISABLED_PROVIDERS=

# Housekeeping / retention
JOB_HOUSEKEEPING_MS=86400000
AUDIT_KEEP_DAYS=30
MATCHES_HISTORY_KEEP_DAYS=120
PROVIDER_SAMPLES_KEEP_DAYS=14
MATCH_SNAPSHOTS_KEEP_DAYS=14
ODDS_MOVEMENTS_KEEP_DAYS=30
PROMPT_SHADOW_KEEP_DAYS=14

# Live analysis prompt is fixed in code as v10-hybrid-legacy-g.
# Do not configure retired active/shadow prompt versions.

# Balanced live value pocket (default off; enable only after promotion gate)
POLICY_BALANCED_LIVE_ENABLED=false
POLICY_BALANCED_LIVE_MIN_ODDS=1.65
POLICY_BALANCED_LIVE_MAX_ODDS=2.00
POLICY_BALANCED_LIVE_MIN_CONFIDENCE=7
POLICY_BALANCED_LIVE_MIN_EDGE=7
POLICY_BALANCED_LIVE_MAX_STAKE_PERCENT=2

# Optional: block recommendations when minuteBand::marketFamily matches (see segment-policy-blocklist.example.json)
# SEGMENT_POLICY_BLOCKLIST_PATH=segment-policy-blocklist.json
# Optional: cap stake % per segment key (see segment-policy-stake-cap.example.json)
# SEGMENT_POLICY_STAKE_CAP_PATH=segment-policy-stake-cap.json
# Line Ladder Patience (default on; see line-patience-policy.example.json + docs/line-ladder-patience-spec.md)
# LINE_PATIENCE_ENABLED=false
# LINE_PATIENCE_CONFIG_PATH=line-patience-policy.json
# Thesis watch: persist LLP deferrals and promote without a second LLM call (default on; requires LLP)
# THESIS_WATCH_ENABLED=false
# THESIS_WATCH_TTL_MINUTES=45
# THESIS_WATCH_KEEP_DAYS=30
