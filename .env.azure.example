# ============================================================
# TFI — Azure Container App environment variables
# Copy this to .env.azure and fill in real values before deploy
# ============================================================

# PostgreSQL (already exists on fkr-database)
DATABASE_URL=postgresql://fkr:<password>@fkr-database.postgres.database.azure.com:5432/tfi?sslmode=require

# Redis (Azure Cache for Redis — pits.redis.cache.windows.net)
REDIS_URL=rediss://:<access-key>@pits.redis.cache.windows.net:6380

# Football API
FOOTBALL_API_KEY=<your-football-api-key>

# AI (Gemini)
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_TIMEOUT_MS=90000
# Live pipeline / default proxy (often Pro in production)
# GEMINI_MODEL=gemini-3-pro-preview
# Auto-settle AI fallback only — cheaper default than full pipeline
GEMINI_SETTLE_MODEL=gemini-2.5-flash
GEMINI_STRATEGIC_GROUNDED_MODEL=gemini-2.5-flash
GEMINI_STRATEGIC_STRUCTURED_MODEL=gemini-2.5-flash
GEMINI_STRATEGIC_GROUNDED_MAX_OUTPUT_TOKENS=4000
GEMINI_STRATEGIC_STRUCTURED_MAX_OUTPUT_TOKENS=2048
GEMINI_STRATEGIC_GROUNDED_THINKING_BUDGET=0
GEMINI_STRATEGIC_STRUCTURED_THINKING_BUDGET=0

# Provider sampling / observability
PROVIDER_SAMPLING_ENABLED=true

# Housekeeping / retention
JOB_HOUSEKEEPING_MS=86400000
AUDIT_KEEP_DAYS=30
MATCHES_HISTORY_KEEP_DAYS=120
PROVIDER_SAMPLES_KEEP_DAYS=14
MATCH_SNAPSHOTS_KEEP_DAYS=14
ODDS_MOVEMENTS_KEEP_DAYS=30
PROMPT_SHADOW_KEEP_DAYS=14

# Live analysis prompts — production: active only; shadow off until candidate version is updated
LIVE_ANALYSIS_ACTIVE_PROMPT_VERSION=v10-hybrid-legacy-b
LIVE_ANALYSIS_SHADOW_PROMPT_VERSION=
LIVE_ANALYSIS_SHADOW_ENABLED=false
LIVE_ANALYSIS_SHADOW_SAMPLE_RATE=0

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# CORS (same-origin in single container — not strictly needed)
CORS_ORIGIN=https://tfi-app.ashywave-e4748b53.koreacentral.azurecontainerapps.io

# Timezone
TIMEZONE=Asia/Seoul

# Google OAuth
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
FRONTEND_URL=https://tfi-app.ashywave-e4748b53.koreacentral.azurecontainerapps.io
JWT_SECRET=<random-secret-at-least-32-chars>
JWT_EXPIRES_IN_SECONDS=86400
ALLOWED_EMAILS=
